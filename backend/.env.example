# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MongoDB)
MONGODB_URI=mongodb://localhost:27017/salon_management

# JWT Configuration
JWT_SECRET=your_very_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your_refresh_token_secret_change_this
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_NAME=Your Salon Name
SMTP_FROM_EMAIL=noreply@yoursalon.com

# Salon Information
SALON_NAME=Your Salon Name
SALON_ADDRESS=123 Main Street, City, State 12345
SALON_PHONE=(555) 123-4567
SALON_EMAIL=info@yoursalon.com

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
